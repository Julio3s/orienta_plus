# ORIENTA+ - Variables d'environnement backend
# Copier ce fichier en .env puis completer les valeurs

SECRET_KEY=django-insecure-change-me-in-production-xxxxxxxxxxxxxxxxxxxxx
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de donnees PostgreSQL
DB_NAME=orienta
DB_USER=orienta_user
DB_PASSWORD=orienta_pass_change_me
DB_HOST=localhost
DB_PORT=5432

# CORS - URL du frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# xAI / Grok
XAI_API_KEY=xai-votre-cle-ici
XAI_API_BASE=https://api.x.ai/v1
XAI_MODEL=grok-3-mini
XAI_MAX_TOKENS=800
XAI_TEMPERATURE=0.7
XAI_REQUEST_TIMEOUT=30
# False = Chat Completions (recommande pour la compatibilite xAI)
XAI_USE_RESPONSES_API=False
XAI_STORE_CONVERSATIONS=False
