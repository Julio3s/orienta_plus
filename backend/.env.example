# ORIENTA+ — Variables d'environnement backend
# Copier ce fichier en .env et remplir les valeurs

SECRET_KEY=django-insecure-change-me-in-production-xxxxxxxxxxxxxxxxxxxxx
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=orienta
DB_USER=orienta_user
DB_PASSWORD=orienta_pass_change_me
DB_HOST=localhost
DB_PORT=5432

# CORS — URL du frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenAI — Remplacer par votre clé réelle
OPENAI_API_KEY=sk-your-openai-key-here
