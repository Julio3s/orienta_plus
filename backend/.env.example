# ORIENTA+ - Variables d'environnement backend
# Copier ce fichier en .env puis completer les valeurs

SECRET_KEY=django-insecure-change-me-in-production-xxxxxxxxxxxxxxxxxxxxx
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de donnees PostgreSQL
DB_NAME=orienta
DB_USER=orienta_user
DB_PASSWORD=orienta_pass_change_me
DB_HOST=localhost
DB_PORT=5432

# CORS - URL du frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Groq
GROQ_API_KEY=gsk_votre_cle_ici
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=800
GROQ_TEMPERATURE=0.7
GROQ_REQUEST_TIMEOUT=30
GROQ_USE_RESPONSES_API=False
GROQ_STORE_CONVERSATIONS=False
